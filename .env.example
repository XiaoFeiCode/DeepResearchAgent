# =============================================================================
# 1. 主语言模型
# =============================================================================
# OpenAI 兼容接口地址，必须包含服务要求的版本路径，例如 /v1。
OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1
# 主语言模型服务的 API Key。
OPENAI_API_KEY=replace-with-your-api-key
# 主智能体使用的模型名称，必须与模型服务实际开放的名称一致。
LLM_MODEL=replace-with-your-model-name

# =============================================================================
# 2. 视觉理解模型
# =============================================================================
# OpenAI 兼容的视觉模型接口；未填写时会复用 OPENAI_BASE_URL。
VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 视觉模型 API Key；未填写时依次复用 DASHSCOPE_API_KEY、OPENAI_API_KEY。
VISION_API_KEY=replace-with-your-dashscope-api-key
# 百炼通用 API Key，可供视觉、Embedding 和 Reranker 共同复用。
DASHSCOPE_API_KEY=
# 支持图片输入的视觉模型名称。
VISION_MODEL=qwen3-vl-flash
# 单张待分析图片的原始大小上限，单位 MB。
VISION_MAX_IMAGE_MB=10
# 视觉模型单次请求超时时间，单位秒。
VISION_REQUEST_TIMEOUT_SECONDS=90

# =============================================================================
# 3. 多模态图片知识库
# =============================================================================
# 百炼多模态 Embedding 接口，用于文本搜图和以图搜图。
# 留空时依次复用 VISION_API_KEY、DASHSCOPE_API_KEY。
# 必须与已有 Milvus 图片 Collection 的向量维度一致。
# 文本检索图片时附加给 Embedding 模型的检索指令。
# 原始上传图片限制，以及送入 Embedding API 前的压缩限制。
# 防止超大图片造成内存占用，分别限制总像素数和最长边。
# 图片检索最低余弦相似度，范围为 -1 到 1。

# =============================================================================
# 4. Redis 短期记忆与任务检查点
# =============================================================================
# 保存当前会话的 LangGraph 状态，用于同一 thread_id 的上下文续接。
REDIS_CHECKPOINT_URL=redis://127.0.0.1:6380
# 不活跃会话检查点的保留时间，10080 分钟等于 7 天。
REDIS_CHECKPOINT_TTL_MINUTES=10080

# =============================================================================
# 5. Milvus 长期记忆与图片向量库
# =============================================================================
MILVUS_URI=http://127.0.0.1:19531
# 无鉴权的本地 Milvus 可以留空；远程服务按实际情况填写。
MILVUS_TOKEN=
MILVUS_MEMORY_COLLECTION=agent_long_term_memory
# 修改维度前需要同步重建对应的 Milvus Collection。
MEMORY_VECTOR_DIMENSION=512
# 长期记忆召回最低余弦相似度。
MEMORY_MIN_SIMILARITY=0.12

# =============================================================================
# 6. 长期记忆 Embedding 与 Reranker
# =============================================================================
# 可选 api、vllm、hash；生产环境建议使用 api 或 vllm。
MEMORY_EMBEDDING_PROVIDER=api
MEMORY_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 留空时依次复用 DASHSCOPE_API_KEY、VISION_API_KEY。
MEMORY_EMBEDDING_API_KEY=
MEMORY_EMBEDDING_MODEL=text-embedding-v4
MEMORY_RERANKER_ENABLED=true
# 可选 api、vllm、none；留空时跟随 MEMORY_EMBEDDING_PROVIDER。
MEMORY_RERANKER_PROVIDER=api
MEMORY_RERANKER_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank
# 留空时依次复用 DASHSCOPE_API_KEY、VISION_API_KEY。
MEMORY_RERANKER_API_KEY=
MEMORY_RERANKER_MODEL=gte-rerank-v2
MEMORY_INFERENCE_TIMEOUT_SECONDS=30
# 远程向量服务异常时是否允许退化为本地哈希向量；默认关闭以避免静默降级。
MEMORY_ALLOW_HASH_FALLBACK=false

# 本地 vLLM Embedding 与 Reranker 服务；仅当 Provider 设为 vllm 时使用。
VLLM_EMBEDDING_BASE_URL=http://127.0.0.1:8001/v1
VLLM_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
VLLM_EMBEDDING_API_KEY=local-vllm
VLLM_RERANKER_BASE_URL=http://127.0.0.1:8002/v1
VLLM_RERANKER_MODEL=BAAI/bge-reranker-base
VLLM_RERANKER_API_KEY=local-vllm
VLLM_INFERENCE_TIMEOUT_SECONDS=30

# =============================================================================
# 7. MySQL 业务数据与会话持久化
# =============================================================================
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=replace-with-your-mysql-user
MYSQL_PASSWORD=replace-with-your-mysql-password
MYSQL_DATABASE=replace-with-your-database-name

# =============================================================================
# 8. RAGFlow 企业知识库
# =============================================================================
# RAGFlow 服务地址和当前用户的 API Key。
RAGFLOW_API_URL=http://127.0.0.1:9380
RAGFLOW_API_KEY=replace-with-your-ragflow-api-key

# =============================================================================
# 9. Daytona 远程安全沙箱
# =============================================================================
# 用于 Agent 执行文件操作和代码任务；未配置时项目会降级到本地受限文件后端。
DAYTONA_API_KEY=replace-with-your-daytona-api-key
DAYTONA_API_URL=https://app.daytona.io/api
# 留空时使用 Daytona 组织默认区域。
DAYTONA_TARGET=
DAYTONA_COMMAND_TIMEOUT_SECONDS=1800
DAYTONA_AUTO_STOP_MINUTES=60
# 沙箱创建遇到临时网络故障时的重试次数和基础等待秒数。
DAYTONA_CREATE_RETRIES=3
DAYTONA_RETRY_DELAY_SECONDS=1

# =============================================================================
# 10. Phoenix 链路观测
# =============================================================================
# 开启后通过 OpenTelemetry/OpenInference 上报 Agent、模型和工具调用链路。
PHOENIX_TRACING_ENABLED=true
PHOENIX_COLLECTOR_ENDPOINT=http://127.0.0.1:6006/v1/traces
PHOENIX_PROJECT_NAME=omniresearch
# 含敏感提示词、回答或图片时建议设为 false。
PHOENIX_CAPTURE_CONTENT=true
PHOENIX_EXPORT_TIMEOUT_SECONDS=10
APP_ENVIRONMENT=development

# =============================================================================
# 11. RAGAS 离线自动评测
# =============================================================================
# 评测集和输出目录均相对于项目根目录；评测会为每条用例创建独立 thread_id。
EVALUATION_DATASET_PATH=evaluation/datasets/cases.jsonl
EVALUATION_OUTPUT_DIR=output/evaluation
EVALUATION_USER_ID=evaluation
# 裁判模型默认复用 OPENAI_* 和 LLM_MODEL；需要隔离费用或模型时单独填写。
EVALUATION_LLM_MODEL=
EVALUATION_LLM_BASE_URL=
EVALUATION_LLM_API_KEY=
# 裁判模型生成结构化评分说明时的最大输出 Token。
EVALUATION_LLM_MAX_TOKENS=8192
# Answer Relevancy 需要 Embedding；默认尝试复用长期记忆的 Embedding 配置。
EVALUATION_EMBEDDING_MODEL=
EVALUATION_EMBEDDING_BASE_URL=
EVALUATION_EMBEDDING_API_KEY=
# 开启后把评测分数作为 Annotation 写回对应的 Phoenix 根 Span。
EVALUATION_PHOENIX_BASE_URL=http://127.0.0.1:6006
EVALUATION_PHOENIX_API_KEY=
EVALUATION_PUBLISH_TO_PHOENIX=false

# =============================================================================
# 12. API 登录、RBAC、限流与历史会话迁移
# =============================================================================
API_AUTH_ENABLED=true
# 生产环境必须替换为足够长的随机字符串。
API_AUTH_SECRET=replace-with-a-long-random-secret
API_TOKEN_EXPIRE_MINUTES=120
# 首次启动时用于创建管理员账号。
API_ADMIN_USERNAME=admin
API_ADMIN_PASSWORD=replace-with-your-admin-password
# 是否额外插入演示用 researcher、operator、viewer 用户。
API_SEED_DEMO_USERS=true
# 当前为单进程内存限流：每个用户或 IP 在时间窗口内允许的请求数。
API_RATE_LIMIT_REQUESTS=120
API_RATE_LIMIT_WINDOW_SECONDS=60
# 旧表缺少 user_id 时，将历史会话归属到该用户；留空则使用管理员用户名。
CONVERSATION_LEGACY_USER_ID=

# =============================================================================
# 13. Tavily 联网搜索
# =============================================================================
TAVILY_API_KEY=replace-with-your-tavily-api-key

# =============================================================================
# 14. 外部 Skill 安装
# =============================================================================
# 默认拒绝安装包中的 Python、Shell、PowerShell 等可执行脚本。
SKILL_ALLOW_EXECUTABLE_FILES=false
# 可选，用于提高 GitHub API 请求限额；只应保存在本地 .env。
GITHUB_TOKEN=

# =============================================================================
# 15. Typst 文档生成
# =============================================================================
# 可选字体目录；Windows 使用分号分隔，Linux/macOS 使用冒号分隔。
TYPST_FONT_PATHS=

# =============================================================================
# 16. 本地 vLLM Docker 部署辅助
# =============================================================================
# 以下变量由 deploy/vllm/docker-compose.yml 使用，不由后端 Settings 直接读取。
VLLM_EMBEDDING_GPU_MEMORY_UTILIZATION=0.35
VLLM_RERANKER_GPU_MEMORY_UTILIZATION=0.35
VLLM_VISION_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
VLLM_VISION_MAX_MODEL_LEN=8192
VLLM_VISION_GPU_MEMORY_UTILIZATION=0.85
# 私有 Hugging Face 模型需要 Token；国内镜像可按需修改 Endpoint。
HF_TOKEN=
HF_ENDPOINT=https://huggingface.co
